---
const llwinUrl = "https://YOUR_WEBSITE.com";
const tiktokUrl = "https://tiktok.com/@YOUR_USERNAME";
const telegramUrl = "https://t.me/+fIPzSraQwp8wNTA1";

import llwinLogo from '../assets/llwin.png';
import tiktokLogo from '../assets/tiktok.png';
import telegramLogo from '../assets/telegram.png';
import avatarImg from '../assets/avt.png';
---

<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NTTP</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        background: #060c18;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        overflow: hidden;
        position: relative;
      }

      /* ── Background layers (z 0-4) ── */

      /* TradingView iframe as bg */
      #tv-bg {
        position: fixed; inset: 0;
        width: 100%; height: 100%;
        z-index: 0;
        border: none;
        opacity: 0.22;          /* subtle — just texture */
        pointer-events: none;
        filter: saturate(0.6);  /* desaturate so it blends dark */
      }

      /* Candle chart on top of TV */
      #trading-canvas {
        position: fixed; inset: 0;
        width: 100%; height: 100%;
        z-index: 1;
      }

      /* Particles */
      #particle-canvas {
        position: fixed; inset: 0;
        width: 100%; height: 100%;
        z-index: 2;
        pointer-events: none;
      }

      /* Vignette — darkens edges so content pops */
      .vignette {
        position: fixed; inset: 0;
        background: radial-gradient(ellipse at center, transparent 25%, #060c18 80%);
        z-index: 3; pointer-events: none;
      }

      /* Extra dark overlay so TV doesn't bleed through centre too much */
      .overlay {
        position: fixed; inset: 0;
        background: rgba(6,12,24,0.55);
        z-index: 3; pointer-events: none;
      }

      .fade-bottom {
        position: fixed; bottom: 0; left: 0; right: 0; height: 200px;
        background: linear-gradient(to top, #060c18 40%, transparent);
        z-index: 4; pointer-events: none;
      }

      /* ── Main content ── */
      main {
        position: relative; z-index: 10;
        display: flex; flex-direction: column;
        align-items: center;
        gap: 18px;
        padding: 32px 20px 28px;
        width: 100%;
        max-width: 400px;
      }

      /* ── Avatar ── */
      .logo-wrap {
        animation: fadeDown 0.7s ease both;
      }
      .avt {
        width: 86px; height: 86px;
        border-radius: 50%; object-fit: cover;
        border: 2px solid rgba(59,130,246,0.55);
        box-shadow: 0 0 28px rgba(59,130,246,0.28);
        display: block;
      }

      /* ── NTTP big name ── */
      .name-block {
        display: flex; flex-direction: column; align-items: center; gap: 10px;
        animation: fadeDown 0.7s 0.08s ease both;
      }
      .name-nttp {
        font-size: clamp(56px, 18vw, 76px);
        font-weight: 800;
        letter-spacing: 0.2em;
        background: linear-gradient(135deg, #ffffff 0%, #93c5fd 45%, #3b82f6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0 0 32px rgba(59,130,246,0.6));
        line-height: 1;
        text-align: center;
      }

      /* ── Typewriter ── */
      .tagline-wrap {
        min-height: 24px;
        display: flex; align-items: center; justify-content: center;
        animation: fadeDown 0.7s 0.14s ease both;
      }
      .tagline {
        color: #94a3b8;
        font-size: 14px;
        font-weight: 400;
        letter-spacing: 0.07em;
      }
      .cursor {
        display: inline-block;
        width: 2px; height: 0.9em;
        background: #3b82f6;
        margin-left: 2px;
        vertical-align: middle;
        animation: blink 0.85s step-end infinite;
      }
      @keyframes blink {
        0%,100% { opacity: 1; }
        50%      { opacity: 0; }
      }

      .divider {
        width: 36px; height: 1px;
        background: rgba(59,130,246,0.35);
        animation: fadeDown 0.7s 0.18s ease both;
      }

      /* ── Link buttons ── */
      .contacts {
        display: flex; flex-direction: column; gap: 10px;
        width: 100%;
        animation: fadeUp 0.7s 0.26s ease both;
      }
      .btn {
        display: flex; align-items: center; gap: 13px;
        padding: 13px 18px; border-radius: 14px;
        text-decoration: none;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.045);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        color: #e2e8f0;
        font-size: 15px; font-weight: 500;
        position: relative; overflow: hidden;
        transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
        /* good touch target on mobile */
        min-height: 56px;
      }
      .btn::before {
        content: ''; position: absolute; inset: 0;
        opacity: 0; transition: opacity 0.18s ease; border-radius: inherit;
      }
      .btn-llwin::before    { background: linear-gradient(135deg,rgba(37,99,235,.18),rgba(37,99,235,.04)); }
      .btn-tiktok::before   { background: linear-gradient(135deg,rgba(37,197,197,.14),rgba(255,0,80,.14)); }
      .btn-telegram::before { background: linear-gradient(135deg,rgba(41,182,246,.18),rgba(37,99,235,.08)); }
      .btn:hover, .btn:active {
        transform: translateY(-2px);
        border-color: rgba(255,255,255,.15);
        box-shadow: 0 8px 28px rgba(0,0,0,.35);
      }
      .btn:hover::before, .btn:active::before { opacity: 1; }

      .btn-icon {
        width: 36px; height: 36px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
      }
      .btn-llwin .btn-icon    { background: #1a2540; }
      .btn-tiktok .btn-icon   { background: #111; }
      .btn-telegram .btn-icon { background: #1da1f2; }
      .btn-icon img { width: 22px; height: 22px; object-fit: contain; }

      .btn-label { flex: 1; }
      .btn-label .name { display: block; font-size: 15px; font-weight: 500; color: #e2e8f0; }
      .btn-label .sub  { display: block; font-size: 12px; color: rgba(148,163,184,.7); margin-top: 1px; }

      .btn-arrow { color: rgba(148,163,184,.4); font-size: 18px; transition: transform .18s ease, color .18s ease; }
      .btn:hover .btn-arrow, .btn:active .btn-arrow {
        transform: translateX(3px); color: rgba(148,163,184,.85);
      }

      /* ── Ticker ── */
      .ticker-wrap {
        width: 100%; overflow: hidden;
        mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
        -webkit-mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
        animation: fadeUp 0.7s 0.34s ease both;
      }
      .ticker-track {
        display: flex; gap: 22px;
        animation: tickerScroll 32s linear infinite;
        width: max-content;
      }
      .ticker-item {
        display: flex; align-items: center; gap: 5px;
        font-size: 11px; font-family: 'SF Mono','Fira Mono',monospace;
        color: rgba(148,163,184,.55); white-space: nowrap;
      }
      .ticker-item .sym { color: rgba(203,213,225,.8); font-weight: 600; }
      .ticker-item .up  { color: #10b981; }
      .ticker-item .dn  { color: #ef4444; }
      .ticker-item .neu { color: #64748b; }

      @keyframes tickerScroll {
        0%   { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      @keyframes fadeDown {
        from { opacity: 0; transform: translateY(-14px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(14px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      /* ── Mobile tweaks ── */
      @media (max-width: 390px) {
        .avt { width: 74px; height: 74px; }
        main { gap: 14px; padding: 24px 16px 20px; }
        .btn { padding: 12px 14px; gap: 11px; }
      }
    </style>
  </head>

  <body>

    <!-- ① TradingView as fullscreen background iframe -->
    <iframe
      id="tv-bg"
      src="https://s.tradingview.com/widgetembed/?symbol=BINANCE%3ABTCUSDT&interval=5&theme=dark&style=1&locale=en&hide_top_toolbar=1&hide_legend=1&hide_side_toolbar=1&allow_symbol_change=0&save_image=0&calendar=0&studies=[]&show_popup_button=0"
      title="BTC chart background"
      loading="lazy"
    ></iframe>

    <!-- ② Candle animation canvas -->
    <canvas id="trading-canvas"></canvas>

    <!-- ③ Particle / star field -->
    <canvas id="particle-canvas"></canvas>

    <!-- ④ Overlays -->
    <div class="overlay"></div>
    <div class="vignette"></div>
    <div class="fade-bottom"></div>

    <!-- ══════════════════════════════════
         MAIN CONTENT
    ══════════════════════════════════ -->
    <main>

      <!-- Avatar -->
      <div class="logo-wrap">
        <img src={avatarImg.src} alt="Avatar" class="avt" />
      </div>

      <!-- Big name + typewriter -->
      <div class="name-block">
        <div class="name-nttp">NTTP</div>
        <div class="tagline-wrap">
          <span class="tagline" id="tagline-text"></span><span class="cursor"></span>
        </div>
      </div>

      <div class="divider"></div>

      <!-- Buttons -->
      <div class="contacts">
        <a href={llwinUrl} target="_blank" rel="noopener" class="btn btn-llwin">
          <div class="btn-icon"><img src={llwinLogo.src} alt="LLwin" /></div>
          <div class="btn-label">
            <span class="name">LLwin</span>
            <span class="sub">Cổng game tốt nhất hiện tại</span>
          </div>
          <span class="btn-arrow">›</span>
        </a>

        <a href={tiktokUrl} target="_blank" rel="noopener" class="btn btn-tiktok">
          <div class="btn-icon"><img src={tiktokLogo.src} alt="TikTok" /></div>
          <div class="btn-label">
            <span class="name">TikTok</span>
            <span class="sub">Phân tích & thực chiến</span>
          </div>
          <span class="btn-arrow">›</span>
        </a>

        <a href={telegramUrl} target="_blank" rel="noopener" class="btn btn-telegram">
          <div class="btn-icon"><img src={telegramLogo.src} alt="Telegram" /></div>
          <div class="btn-label">
            <span class="name">Telegram</span>
            <span class="sub">Chia sẻ & giao lưu</span>
          </div>
          <span class="btn-arrow">›</span>
        </a>
      </div>

      <!-- Live ticker -->
      <div class="ticker-wrap">
        <div class="ticker-track" id="ticker-track">
          <span class="ticker-item"><span class="sym">BTC/USDT</span> <span class="neu">—</span></span>
        </div>
      </div>

    </main>

    <!-- ══════════════════════════════════
         SCRIPT 1 – Candle background
    ══════════════════════════════════ -->
    <script is:inline>
      (() => {
        const canvas = document.getElementById('trading-canvas');
        const ctx = canvas.getContext('2d');
        let W, H, candles = [];
        const CW = 10, GAP = 6, STEP = CW + GAP;

        function resize() {
          W = canvas.width = window.innerWidth;
          H = canvas.height = window.innerHeight;
          generateCandles();
        }
        function generateCandles() {
          const n = Math.ceil(W / STEP) + 4;
          candles = [];
          let p = 0.4 + Math.random() * 0.2;
          for (let i = 0; i < n; i++) {
            const open = p;
            p = Math.max(0.05, Math.min(0.95, p + (Math.random() - 0.48) * 0.06));
            const close = p;
            candles.push({ open, close,
              high: Math.max(open,close) + Math.random()*0.025,
              low:  Math.min(open,close) - Math.random()*0.025 });
          }
        }
        function evolve() {
          candles.shift();
          const prev = candles[candles.length-1].close;
          const open = prev;
          const close = Math.max(0.05, Math.min(0.95, prev + (Math.random()-0.48)*0.06));
          candles.push({ open, close,
            high: Math.max(open,close)+Math.random()*0.025,
            low:  Math.min(open,close)-Math.random()*0.025 });
        }
        function draw(off) {
          ctx.clearRect(0,0,W,H);
          const padT=H*0.08, chartH=H*0.84;
          const py = v => padT+(1-v)*chartH;
          ctx.strokeStyle='rgba(37,99,235,0.05)';ctx.lineWidth=0.5;
          for(let g=0;g<=4;g++){const y=padT+(g/4)*chartH;ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}
          candles.forEach((c,i)=>{
            const x=i*STEP-off+STEP;
            if(x<-STEP||x>W+STEP)return;
            const bull=c.close>=c.open;
            const col=bull?'#10b981':'#ef4444';
            const colA=bull?'rgba(16,185,129,':'rgba(239,68,68,';
            const oY=py(c.open),cY=py(c.close);
            const top=Math.min(oY,cY),bH=Math.max(1,Math.abs(cY-oY));
            const g2=ctx.createLinearGradient(x,top,x,top+bH+40);
            g2.addColorStop(0,colA+'0.14)');g2.addColorStop(1,colA+'0)');
            ctx.fillStyle=g2;ctx.fillRect(x-CW/2,top,CW,bH+40);
            ctx.strokeStyle=col;ctx.globalAlpha=0.45;ctx.lineWidth=1;
            ctx.beginPath();ctx.moveTo(x,py(c.high));ctx.lineTo(x,py(c.low));ctx.stroke();
            ctx.fillStyle=col;ctx.globalAlpha=bull?0.68:0.55;
            ctx.fillRect(x-CW/2,top,CW,bH);ctx.globalAlpha=1;
          });
          ctx.beginPath();ctx.strokeStyle='rgba(37,99,235,0.28)';ctx.lineWidth=1.5;
          const ml=7;
          for(let i=ml;i<candles.length;i++){
            const avg=candles.slice(i-ml,i).reduce((s,c)=>s+(c.open+c.close)/2,0)/ml;
            const x=i*STEP-off+STEP;
            if(i===ml)ctx.moveTo(x,py(avg));else ctx.lineTo(x,py(avg));
          }
          ctx.stroke();
        }
        let offset=0;
        (function loop(){
          offset+=0.35;
          if(offset>=STEP){offset-=STEP;evolve();}
          draw(offset);
          requestAnimationFrame(loop);
        })();
        window.addEventListener('resize',resize);
        resize();
      })();
    </script>

    <!-- ══════════════════════════════════
         SCRIPT 2 – Particle field
    ══════════════════════════════════ -->
    <script is:inline>
      (() => {
        const canvas=document.getElementById('particle-canvas');
        const ctx=canvas.getContext('2d');
        let W,H,stars=[];
        const N=80;
        function resize(){
          W=canvas.width=window.innerWidth;
          H=canvas.height=window.innerHeight;
          stars=Array.from({length:N},()=>mk());
        }
        function mk(){
          return{x:Math.random()*(W||390),y:Math.random()*(H||844),
            r:Math.random()*1.1+0.2,speed:Math.random()*0.16+0.04,
            alpha:Math.random()*0.45+0.12,drift:(Math.random()-0.5)*0.1,
            pulse:Math.random()*Math.PI*2};
        }
        (function loop(){
          ctx.clearRect(0,0,W,H);
          stars.forEach(s=>{
            s.y-=s.speed;s.x+=s.drift;s.pulse+=0.012;
            if(s.y<-4||s.x<-4||s.x>W+4){Object.assign(s,mk());s.y=H+4;s.x=Math.random()*W;}
            const a=s.alpha*(0.7+0.3*Math.sin(s.pulse));
            ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);
            ctx.fillStyle=`rgba(147,197,253,${a})`;ctx.fill();
          });
          requestAnimationFrame(loop);
        })();
        window.addEventListener('resize',resize);
        resize();
      })();
    </script>

    <!-- ══════════════════════════════════
         SCRIPT 3 – Typewriter tagline
    ══════════════════════════════════ -->
    <script is:inline>
      (() => {
        const lines=['Tư vấn cổng nạp','Hiểu cơ chế game','Tư vấn tài chính'];
        const el=document.getElementById('tagline-text');
        let li=0,ci=0,del=false;
        function tick(){
          const line=lines[li];
          if(!del){
            el.textContent=line.slice(0,++ci);
            if(ci>=line.length){del=true;setTimeout(tick,2200);return;}
            setTimeout(tick,72);
          } else {
            el.textContent=line.slice(0,--ci);
            if(ci<=0){del=false;li=(li+1)%lines.length;setTimeout(tick,380);return;}
            setTimeout(tick,36);
          }
        }
        setTimeout(tick,900);
      })();
    </script>

    <!-- ══════════════════════════════════
         SCRIPT 4 – Real-time ticker
    ══════════════════════════════════ -->
    <script is:inline>
      (() => {
        const COINS=[
          {id:'bitcoin',sym:'BTC/USDT'},{id:'ethereum',sym:'ETH/USDT'},
          {id:'solana',sym:'SOL/USDT'},{id:'binancecoin',sym:'BNB/USDT'},
          {id:'ripple',sym:'XRP/USDT'},{id:'dogecoin',sym:'DOGE/USDT'},
          {id:'cardano',sym:'ADA/USDT'},{id:'avalanche-2',sym:'AVAX/USDT'},
        ];
        const track=document.getElementById('ticker-track');
        function render(data){
          const html=COINS.map(c=>{
            const d=data[c.id];if(!d)return'';
            const pct=d.usd_24h_change,price=d.usd;
            const cls=pct>0?'up':pct<0?'dn':'neu';
            const arr=pct>0?'▲':pct<0?'▼':'–';
            const ps=(pct>=0?'+':'')+pct.toFixed(2)+'%';
            const pr=price>=1?'$'+price.toLocaleString('en-US',{maximumFractionDigits:2}):'$'+price.toFixed(5);
            return`<span class="ticker-item"><span class="sym">${c.sym}</span><span class="${cls}">${arr} ${ps}</span><span style="color:rgba(148,163,184,.4)">${pr}</span></span>`;
          }).join('');
          track.innerHTML=html+html;
        }
        async function fetch_prices(){
          try{
            const ids=COINS.map(c=>c.id).join(',');
            const r=await fetch(`https://api.coingecko.com/api/v3/simple/price?ids=${ids}&vs_currencies=usd&include_24hr_change=true`,{cache:'no-store'});
            if(r.ok)render(await r.json());
          }catch(e){console.warn('ticker:',e);}
        }
        fetch_prices();
        setInterval(fetch_prices,60000);
      })();
    </script>

  </body>
</html>
