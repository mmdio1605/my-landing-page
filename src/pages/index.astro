---
const llwinUrl = "https://YOUR_WEBSITE.com";
const tiktokUrl = "https://tiktok.com/@YOUR_USERNAME";
const telegramUrl = "https://t.me/+fIPzSraQwp8wNTA1";

import llwinLogo from '../assets/llwin.png';
import tiktokLogo from '../assets/tiktok.png';
import telegramLogo from '../assets/telegram.png';
import avatarImg from '../assets/avt.png';
---

<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LLwin</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: #060c18;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        overflow: hidden;
        position: relative;
      }

      #trading-canvas {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
      }

      .vignette {
        position: fixed;
        inset: 0;
        background: radial-gradient(ellipse at center, transparent 40%, #060c18 90%);
        z-index: 1;
        pointer-events: none;
      }

      .fade-bottom {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: 200px;
        background: linear-gradient(to top, #060c18, transparent);
        z-index: 1;
        pointer-events: none;
      }

      main {
        position: relative;
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 32px;
        padding: 24px;
        width: 100%;
        max-width: 420px;
      }

      .logo-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 14px;
        animation: fadeDown 0.7s ease both;
      }

      .logo-wrap .avt {
        width: 84px;
        height: 84px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid rgba(37, 99, 235, 0.5);
        box-shadow: 0 0 20px rgba(37, 99, 235, 0.25);
      }

      .logo-wrap .logo {
        height: 48px;
        width: auto;
        filter: drop-shadow(0 0 20px rgba(37, 99, 235, 0.5));
      }

      .tagline {
        color: #ffffff;
          font-size: 16px;
          font-weight: 600;
          letter-spacing: 0.04em;
          text-transform: none;
          text-align: center;
          animation: fadeDown 0.7s 0.1s ease both;
      }

      .divider {
        width: 40px;
        height: 1px;
        background: rgba(37, 99, 235, 0.4);
        animation: fadeDown 0.7s 0.15s ease both;
      }

      .contacts {
        display: flex;
        flex-direction: column;
        gap: 12px;
        width: 100%;
        animation: fadeUp 0.7s 0.25s ease both;
      }

      .btn {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 20px;
        border-radius: 14px;
        text-decoration: none;
        transition: transform 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
        border: 1px solid rgba(255,255,255,0.07);
        background: rgba(255,255,255,0.04);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        color: #e2e8f0;
        font-size: 15px;
        font-weight: 500;
        position: relative;
        overflow: hidden;
      }

      .btn::before {
        content: '';
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.18s ease;
        border-radius: inherit;
      }

      .btn-llwin::before {
        background: linear-gradient(135deg, rgba(37,99,235,0.15), rgba(37,99,235,0.05));
      }

      .btn-tiktok::before {
        background: linear-gradient(135deg, rgba(37,197,197,0.12), rgba(255,0,80,0.12));
      }

      .btn-telegram::before {
        background: linear-gradient(135deg, rgba(41,182,246,0.15), rgba(37,99,235,0.1));
      }

      .btn:hover {
        transform: translateY(-2px);
        border-color: rgba(255,255,255,0.14);
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
      }

      .btn:hover::before {
        opacity: 1;
      }

      .btn-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .btn-llwin .btn-icon {
        background: #1a2540;
      }

      .btn-tiktok .btn-icon {
        background: #111;
      }

      .btn-telegram .btn-icon {
        background: #1da1f2;
      }

      .btn-icon img {
        width: 22px;
        height: 22px;
        object-fit: contain;
      }

      .btn-label {
        flex: 1;
      }

      .btn-label .name {
        display: block;
        font-size: 15px;
        font-weight: 500;
        color: #e2e8f0;
      }

      .btn-label .sub {
        display: block;
        font-size: 12px;
        color: rgba(148,163,184,0.7);
        margin-top: 1px;
      }

      .btn-arrow {
        color: rgba(148,163,184,0.4);
        font-size: 18px;
        transition: transform 0.18s ease, color 0.18s ease;
      }

      .btn:hover .btn-arrow {
        transform: translateX(3px);
        color: rgba(148,163,184,0.8);
      }

      .ticker-wrap {
        width: 100%;
        overflow: hidden;
        mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
        -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
        animation: fadeUp 0.7s 0.35s ease both;
      }

      .ticker-track {
        display: flex;
        gap: 24px;
        animation: tickerScroll 28s linear infinite;
        width: max-content;
      }

      .ticker-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-family: 'SF Mono', 'Fira Mono', monospace;
        color: rgba(148,163,184,0.6);
        white-space: nowrap;
      }

      .ticker-item .sym {
        color: rgba(203,213,225,0.8);
        font-weight: 600;
      }

      .ticker-item .up { color: #10b981; }
      .ticker-item .dn { color: #ef4444; }

      @keyframes tickerScroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }

      @keyframes fadeDown {
        from { opacity: 0; transform: translateY(-16px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      @media (max-width: 480px) {
        .logo-wrap .logo { height: 40px; }
        .logo-wrap .avt { width: 72px; height: 72px; }
        main { gap: 24px; }
      }
    </style>
  </head>

  <body>
    <canvas id="trading-canvas"></canvas>
    <div class="vignette"></div>
    <div class="fade-bottom"></div>

    <main>
      <div class="logo-wrap">
        <img src={avatarImg.src} alt="Avatar" class="avt" />
      </div>

      <p class="tagline">NTTP</p>
      <div class="divider"></div>

      <div class="contacts">
        <a href={llwinUrl} target="_blank" rel="noopener" class="btn btn-llwin">
          <div class="btn-icon">
            <img src={llwinLogo.src} alt="LLwin" />
          </div>
          <div class="btn-label">
            <span class="name">LLwin</span>
            <span class="sub">Cổng game tốt nhất hiện tại</span>
          </div>
          <span class="btn-arrow">›</span>
        </a>

        <a href={tiktokUrl} target="_blank" rel="noopener" class="btn btn-tiktok">
          <div class="btn-icon">
            <img src={tiktokLogo.src} alt="TikTok" />
          </div>
          <div class="btn-label">
            <span class="name">TikTok</span>
            <span class="sub">Phân tích & thực chiến</span>
          </div>
          <span class="btn-arrow">›</span>
        </a>

        <a href={telegramUrl} target="_blank" rel="noopener" class="btn btn-telegram">
          <div class="btn-icon">
            <img src={telegramLogo.src} alt="Telegram" />
          </div>
          <div class="btn-label">
            <span class="name">Telegram</span>
            <span class="sub">Chia sẻ & giao lưu</span>
          </div>
          <span class="btn-arrow">›</span>
        </a>
      </div>

      <div class="ticker-wrap">
        <div class="ticker-track">
          <span class="ticker-item"><span class="sym">BTC/USDT</span> <span class="up">▲ +2.34%</span></span>
          <span class="ticker-item"><span class="sym">ETH/USDT</span> <span class="dn">▼ -0.87%</span></span>
          <span class="ticker-item"><span class="sym">SOL/USDT</span> <span class="up">▲ +5.12%</span></span>
          <span class="ticker-item"><span class="sym">BNB/USDT</span> <span class="up">▲ +1.05%</span></span>
          <span class="ticker-item"><span class="sym">XRP/USDT</span> <span class="dn">▼ -1.43%</span></span>
          <span class="ticker-item"><span class="sym">DOGE/USDT</span> <span class="up">▲ +3.67%</span></span>
          <span class="ticker-item"><span class="sym">ADA/USDT</span> <span class="dn">▼ -0.22%</span></span>
          <span class="ticker-item"><span class="sym">AVAX/USDT</span> <span class="up">▲ +4.88%</span></span>
          <span class="ticker-item"><span class="sym">BTC/USDT</span> <span class="up">▲ +2.34%</span></span>
          <span class="ticker-item"><span class="sym">ETH/USDT</span> <span class="dn">▼ -0.87%</span></span>
          <span class="ticker-item"><span class="sym">SOL/USDT</span> <span class="up">▲ +5.12%</span></span>
          <span class="ticker-item"><span class="sym">BNB/USDT</span> <span class="up">▲ +1.05%</span></span>
          <span class="ticker-item"><span class="sym">XRP/USDT</span> <span class="dn">▼ -1.43%</span></span>
          <span class="ticker-item"><span class="sym">DOGE/USDT</span> <span class="up">▲ +3.67%</span></span>
          <span class="ticker-item"><span class="sym">ADA/USDT</span> <span class="dn">▼ -0.22%</span></span>
          <span class="ticker-item"><span class="sym">AVAX/USDT</span> <span class="up">▲ +4.88%</span></span>
        </div>
      </div>
    </main>

    <script is:inline>
      (() => {
        const canvas = document.getElementById('trading-canvas');
        const ctx = canvas.getContext('2d');

        let W, H, candles = [];
        const COLS = { up: '#10b981', dn: '#ef4444', upA: 'rgba(16,185,129,', dnA: 'rgba(239,68,68,' };
        const CANDLE_W = 10, GAP = 6, STEP = CANDLE_W + GAP;

        function resize() {
          W = canvas.width = window.innerWidth;
          H = canvas.height = window.innerHeight;
          generateCandles();
        }

        function generateCandles() {
          const count = Math.ceil(W / STEP) + 4;
          candles = [];
          let price = 0.4 + Math.random() * 0.2;
          for (let i = 0; i < count; i++) {
            const change = (Math.random() - 0.48) * 0.06;
            const open = price;
            price = Math.max(0.05, Math.min(0.95, price + change));
            const close = price;
            const high = Math.max(open, close) + Math.random() * 0.025;
            const low  = Math.min(open, close) - Math.random() * 0.025;
            candles.push({ open, close, high, low });
          }
        }

        function evolve() {
          candles.shift();
          const last = candles[candles.length - 1];
          const prev = last.close;
          const change = (Math.random() - 0.48) * 0.06;
          const open = prev;
          const close = Math.max(0.05, Math.min(0.95, prev + change));
          const high = Math.max(open, close) + Math.random() * 0.025;
          const low  = Math.min(open, close) - Math.random() * 0.025;
          candles.push({ open, close, high, low });
        }

        function drawChart(offsetX) {
          const padT = H * 0.08, padB = H * 0.08;
          const chartH = H - padT - padB;
          function py(v) { return padT + (1 - v) * chartH; }

          ctx.strokeStyle = 'rgba(37,99,235,0.06)';
          ctx.lineWidth = 0.5;
          for (let g = 0; g <= 4; g++) {
            const y = padT + (g / 4) * chartH;
            ctx.beginPath();
            ctx.moveTo(0, y);
            ctx.lineTo(W, y);
            ctx.stroke();
          }

          candles.forEach((c, i) => {
            const x = i * STEP - offsetX + STEP;
            if (x < -STEP || x > W + STEP) return;

            const bull = c.close >= c.open;
            const col = bull ? COLS.up : COLS.dn;
            const colA = bull ? COLS.upA : COLS.dnA;

            const openY  = py(c.open);
            const closeY = py(c.close);
            const highY  = py(c.high);
            const lowY   = py(c.low);
            const bodyTop    = Math.min(openY, closeY);
            const bodyBottom = Math.max(openY, closeY);
            const bodyH = Math.max(1, bodyBottom - bodyTop);

            const grad = ctx.createLinearGradient(x, bodyTop, x, bodyBottom + 40);
            grad.addColorStop(0, colA + '0.18)');
            grad.addColorStop(1, colA + '0)');
            ctx.fillStyle = grad;
            ctx.fillRect(x - CANDLE_W / 2, bodyTop, CANDLE_W, bodyH + 40);

            ctx.strokeStyle = col;
            ctx.globalAlpha = 0.55;
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(x, highY);
            ctx.lineTo(x, lowY);
            ctx.stroke();
            ctx.globalAlpha = 1;

            ctx.fillStyle = col;
            ctx.globalAlpha = bull ? 0.75 : 0.6;
            ctx.fillRect(x - CANDLE_W / 2, bodyTop, CANDLE_W, bodyH);
            ctx.globalAlpha = 1;
          });

          ctx.beginPath();
          ctx.strokeStyle = 'rgba(37,99,235,0.35)';
          ctx.lineWidth = 1.5;
          const maLen = 7;
          for (let i = maLen; i < candles.length; i++) {
            const avg = candles.slice(i - maLen, i).reduce((s, c) => s + (c.open + c.close) / 2, 0) / maLen;
            const x = i * STEP - offsetX + STEP;
            const y = py(avg);
            if (i === maLen) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
          }
          ctx.stroke();
        }

        let offset = 0;
        const SPEED = 0.4;

        function draw() {
          ctx.clearRect(0, 0, W, H);
          offset += SPEED;
          if (offset >= STEP) {
            offset -= STEP;
            evolve();
          }
          drawChart(offset);
          requestAnimationFrame(draw);
        }

        window.addEventListener('resize', resize);
        resize();
        draw();
      })();
    </script>
  </body>
</html>
