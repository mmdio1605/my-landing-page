---
const llwinUrl = "https://YOUR_WEBSITE.com";
const tiktokUrl = "https://tiktok.com/@YOUR_USERNAME";
const telegramUrl = "https://t.me/+fIPzSraQwp8wNTA1";

// Dùng ảnh tĩnh từ assets (đảm bảo file tồn tại khi build)
import llwinLogo from '../assets/llwin.png';
import tiktokLogo from '../assets/tiktok.png';
import telegramLogo from '../assets/telegram.png';
import avatarImg from '../assets/avt.png';
---

<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NTTP</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #060c18;
      min-height: 100vh; min-height: 100dvh;
      display: flex; align-items: center; justify-content: center;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      overflow-x: hidden; overflow-y: auto; position: relative;
    }

    /* Nền tĩnh thay vì canvas */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: radial-gradient(ellipse at 50% 50%, rgba(37,99,235,0.08) 0%, transparent 60%),
                  linear-gradient(180deg, #060c18 0%, #0a1428 100%);
      z-index: 0;
    }

    /* Vignette & fade giữ nguyên */
    .vignette {
      position: fixed; inset: 0;
      background: radial-gradient(ellipse 90% 80% at 50% 50%, transparent 35%, rgba(6,12,24,0.45) 75%, #060c18 100%);
      z-index: 2; pointer-events: none;
    }
    .fade-top {
      position: fixed; top: 0; left: 0; right: 0; height: 70px;
      background: linear-gradient(to bottom, rgba(6,12,24,0.45) 0%, transparent 100%);
      z-index: 2; pointer-events: none;
    }
    .fade-bottom {
      position: fixed; bottom: 0; left: 0; right: 0; height: 160px;
      background: linear-gradient(to top, #060c18 0%, transparent 100%);
      z-index: 2; pointer-events: none;
    }

    main {
      position: relative; z-index: 10; width: 100%; max-width: 400px;
      min-height: 100dvh; display: flex; flex-direction: column;
      justify-content: center; align-items: center; gap: 18px;
      padding: 48px 20px 40px;
    }

    /* Avatar & name giữ nguyên */
    .logo-wrap { animation: fadeDown 0.6s ease both; }
    .avt {
      width: 84px; height: 84px; border-radius: 50%; object-fit: cover;
      border: 2.5px solid rgba(59,130,246,0.6);
      box-shadow: 0 0 0 4px rgba(59,130,246,0.12), 0 0 32px rgba(59,130,246,0.3);
      display: block;
    }
    .name-block { display: flex; flex-direction: column; align-items: center; gap: 10px; animation: fadeDown 0.6s 0.1s ease both; }
    .name-nttp {
      font-size: clamp(54px, 20vw, 78px); font-weight: 800; letter-spacing: 0.22em;
      line-height: 1; text-align: center;
      background: linear-gradient(140deg, #ffffff 0%, #bfdbfe 40%, #3b82f6 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; filter: drop-shadow(0 0 24px rgba(59,130,246,0.5));
    }
    .tagline { color: #94a3b8; font-size: 14px; letter-spacing: 0.08em; }
    .divider { width: 32px; height: 1px; background: rgba(59,130,246,0.35); margin: 0 auto; }

    /* Buttons */
    .contacts { width: 100%; display: flex; flex-direction: column; gap: 10px; animation: fadeUp 0.6s 0.24s ease both; }
    .btn {
      position: relative; overflow: hidden; display: flex; align-items: center; gap: 13px;
      min-height: 58px; padding: 13px 16px; border-radius: 14px; text-decoration: none;
      color: #e2e8f0; font-size: 15px; font-weight: 500;
      border: 1px solid rgba(255,255,255,0.09); background: rgba(255,255,255,0.05);
      backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      transition: transform 0.15s, border-color 0.15s, box-shadow 0.15s;
    }
    .btn::before { content: ''; position: absolute; inset: 0; opacity: 0; border-radius: inherit; transition: opacity 0.15s; }
    .btn-llwin::before { background: linear-gradient(135deg, rgba(37,99,235,0.2), rgba(37,99,235,0.05)); }
    .btn-tiktok::before { background: linear-gradient(135deg, rgba(20,184,166,0.18), rgba(244,63,94,0.15)); }
    .btn-telegram::before { background: linear-gradient(135deg, rgba(14,165,233,0.2), rgba(37,99,235,0.08)); }
    .btn:hover { transform: translateY(-2px); border-color: rgba(255,255,255,0.18); box-shadow: 0 12px 32px rgba(0,0,0,0.3); }
    .btn:hover::before { opacity: 1; }
    .btn-icon { width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .btn-llwin .btn-icon { background: #1a2540; }
    .btn-tiktok .btn-icon { background: #0d0d0d; }
    .btn-telegram .btn-icon { background: #0ea5e9; }
    .btn-icon img { width: 22px; height: 22px; object-fit: contain; }
    .btn-label { flex: 1; }
    .btn-label .name { display: block; font-size: 15px; font-weight: 600; color: #f1f5f9; }
    .btn-label .sub { display: block; margin-top: 2px; font-size: 12px; color: rgba(148,163,184,0.7); }
    .btn-arrow { color: rgba(148,163,184,0.4); font-size: 20px; }

    /* TICKER TĨNH – KHÔNG CẦN JS */
    .ticker-wrap {
      width: 100%; overflow: hidden; position: relative; z-index: 50;
      margin-top: 8px; padding: 6px 0;
    }
    .ticker-track {
      display: flex; gap: 24px; width: max-content;
      animation: tickerScroll 35s linear infinite;
    }
    .ticker-item {
      display: flex; align-items: center; gap: 8px; white-space: nowrap;
      font-size: 13px; font-family: 'SF Mono', 'Fira Mono', monospace;
      color: #f8fafc !important; /* Đảm bảo toàn bộ chữ sáng */
    }
    /* Badge coin */
    .coin-badge {
      width: 24px; height: 24px; border-radius: 50%;
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; flex-shrink: 0;
      box-shadow: 0 2px 8px rgba(0,0,0,0.3);
      color: #fff; /* mặc định trắng */
    }
    .coin-btc { background: #f7931a; }
    .coin-eth { background: #627eea; }
    .coin-sol { background: #14f195; color: #000; } /* chữ đen cho nền sáng */
    .coin-xrp { background: #0085d0; }

    /* Màu cho từng phần tử trong ticker */
    .ticker-item .sym {
      color: #ffffff;
      font-weight: 700;
      text-shadow: 0 0 8px rgba(59,130,246,0.6);
    }
    .ticker-item .change {
      font-weight: 600;
    }
    .ticker-item .up { color: #22c55e; }
    .ticker-item .dn { color: #ef4444; }
    .ticker-item .neu { color: #94a3b8; }
    .ticker-item .price {
      color: #ffffff;
      font-weight: 600;
    }

    @keyframes tickerScroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    @keyframes fadeDown {
      from { opacity: 0; transform: translateY(-14px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <div class="vignette"></div>
  <div class="fade-top"></div>
  <div class="fade-bottom"></div>

  <main>
    <!-- Avatar -->
    <div class="logo-wrap">
      <img src={avatarImg.src} alt="Avatar" class="avt" />
    </div>

    <!-- Tên & tagline -->
    <div class="name-block">
      <div class="name-nttp">NTTP</div>
      <div class="tagline">Tư vấn cổng nạp – Hiểu cơ chế game – Tư vấn tài chính</div>
    </div>

    <div class="divider"></div>

    <!-- Nút liên kết -->
    <div class="contacts">
      <a href={llwinUrl} target="_blank" rel="noopener" class="btn btn-llwin">
        <div class="btn-icon"><img src={llwinLogo.src} alt="LLwin" /></div>
        <div class="btn-label">
          <span class="name">LLwin</span>
          <span class="sub">Cổng game tốt nhất hiện tại</span>
        </div>
        <span class="btn-arrow">›</span>
      </a>
      <a href={tiktokUrl} target="_blank" rel="noopener" class="btn btn-tiktok">
        <div class="btn-icon"><img src={tiktokLogo.src} alt="TikTok" /></div>
        <div class="btn-label">
          <span class="name">TikTok</span>
          <span class="sub">Phân tích & thực chiến</span>
        </div>
        <span class="btn-arrow">›</span>
      </a>
      <a href={telegramUrl} target="_blank" rel="noopener" class="btn btn-telegram">
        <div class="btn-icon"><img src={telegramLogo.src} alt="Telegram" /></div>
        <div class="btn-label">
          <span class="name">Telegram</span>
          <span class="sub">Chia sẻ & giao lưu</span>
        </div>
        <span class="btn-arrow">›</span>
      </a>
    </div>

    <!-- Ticker tĩnh (bạn tự cập nhật giá thủ công) -->
    <div class="ticker-wrap">
      <div class="ticker-track">
        <!-- Bộ 1 -->
        <span class="ticker-item">
          <span class="coin-badge coin-btc">B</span>
          <span class="sym">BTC/USDT</span>
          <span class="change up">▲ +1.23%</span>
          <span class="price">$69,420</span>
        </span>
        <span class="ticker-item">
          <span class="coin-badge coin-eth">E</span>
          <span class="sym">ETH/USDT</span>
          <span class="change dn">▼ -0.45%</span>
          <span class="price">$3,510</span>
        </span>
        <span class="ticker-item">
          <span class="coin-badge coin-sol">S</span>
          <span class="sym">SOL/USDT</span>
          <span class="change up">▲ +2.10%</span>
          <span class="price">$145.80</span>
        </span>
        <span class="ticker-item">
          <span class="coin-badge coin-xrp">X</span>
          <span class="sym">XRP/USDT</span>
          <span class="change neu">– 0.00%</span>
          <span class="price">$0.528</span>
        </span>
        <!-- Nhân đôi để cuộn mượt -->
        <span class="ticker-item">
          <span class="coin-badge coin-btc">B</span>
          <span class="sym">BTC/USDT</span>
          <span class="change up">▲ +1.23%</span>
          <span class="price">$69,420</span>
        </span>
        <span class="ticker-item">
          <span class="coin-badge coin-eth">E</span>
          <span class="sym">ETH/USDT</span>
          <span class="change dn">▼ -0.45%</span>
          <span class="price">$3,510</span>
        </span>
        <span class="ticker-item">
          <span class="coin-badge coin-sol">S</span>
          <span class="sym">SOL/USDT</span>
          <span class="change up">▲ +2.10%</span>
          <span class="price">$145.80</span>
        </span>
        <span class="ticker-item">
          <span class="coin-badge coin-xrp">X</span>
          <span class="sym">XRP/USDT</span>
          <span class="change neu">– 0.00%</span>
          <span class="price">$0.528</span>
        </span>
      </div>
    </div>
  </main>
</body>
</html>
